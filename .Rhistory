library(tidyverse)
library(ggpubr)
library(readxl)
library(scales)
library(fmsb)
# 1. 从Excel读取数据（假设文件名为evaluation_results.xlsx）
df1 <- read_excel("D:/AAA_UZH_study/Project/SNPic/results_part2/simulation_evaluation_results.xlsx", sheet = 1) # 第一个表
# 2. 折线图函数
plot_metric_trend <- function(metric, title) {
df %>%
ggplot(aes(x=round, y=.data[[metric]], color=model, group=model)) +
geom_line(linewidth=1.2) +
geom_point(size=3) +
labs(title=title, x="Round", y=metric) +
scale_color_brewer(palette="Set1") +
theme_minimal() +
theme(legend.position="top")
}
View(df1)
# 3. 生成所有指标的折线图
p1 <- plot_metric_trend("mse", "MSE Trend (Lower is better)")
# 2. 修正后的折线图函数
plot_metric_trend <- function(data, metric, title) {
ggplot(data, aes(x = round, y = .data[[metric]], color = model, group = model)) +
geom_line(linewidth = 1.2) +
geom_point(size = 3) +
labs(title = title, x = "Round", y = metric) +
scale_color_brewer(palette = "Set1") +
theme_minimal() +
theme(legend.position = "top")
}
# 3. 生成所有指标的折线图（现在需要传入data参数）
p1 <- plot_metric_trend(df, "mse", "MSE Trend (Lower is better)")
View(df)
library(tidyverse)
library(ggpubr)
library(readxl)
library(scales)
library(fmsb)
# 1. 从Excel读取数据（假设文件名为evaluation_results.xlsx）
df <- read_excel("D:/AAA_UZH_study/Project/SNPic/results_part2/simulation_evaluation_results.xlsx", sheet = 1) # 第一个表
# 2. 修正后的折线图函数
plot_metric_trend <- function(data, metric, title) {
ggplot(data, aes(x = round, y = .data[[metric]], color = model, group = model)) +
geom_line(linewidth = 1.2) +
geom_point(size = 3) +
labs(title = title, x = "Round", y = metric) +
scale_color_brewer(palette = "Set1") +
theme_minimal() +
theme(legend.position = "top")
}
# 3. 生成所有指标的折线图（现在需要传入data参数）
p1 <- plot_metric_trend(df, "mse", "MSE Trend (Lower is better)")
p2 <- plot_metric_trend(df, "cor", "Correlation Trend")
p3 <- plot_metric_trend(df, "sil", "Silhouette Score Trend")
p4 <- plot_metric_trend(df, "dcor", "Distance Correlation Trend")
p5 <- plot_metric_trend(df, "trust", "Trustworthiness Trend")
p6 <- plot_metric_trend(df, "conti", "Continuity Trend")
# 4. 组合折线图
ggarrange(p1, p2, p3, p4, p5, p6,
ncol=2, nrow=3, common.legend=TRUE)
# 5. 雷达图（需要标准化数据）
library(fmsb)
radar_data <- df %>%
group_by(model) %>%
summarise(across(c(mse, cor, sil, dcor, trust, conti), mean)) %>%
mutate(mse = 1 - rescale(mse)) %>%  # 反转MSE
select(-model) %>%
as.data.frame() %>%
`rownames<-`(unique(df$model)) %>%
rbind(rep(1,6), rep(0,6))  # 雷达图范围
# 绘制雷达图
radarchart(radar_data, axistype=1,
pcol=rainbow(4), plwd=2, plty=1,
cglcol="grey", cglty=1, cglwd=0.8,
vlcex=0.8, title="Model Performance Radar Chart")
# 6. 箱线图比较分布
df_long <- df %>%
pivot_longer(cols=c(mse, cor, sil, dcor, trust, conti),
names_to="metric", values_to="value")
ggplot(df_long, aes(x=model, y=value, fill=model)) +
geom_boxplot() +
facet_wrap(~metric, scales="free_y") +
scale_fill_brewer(palette="Pastel1") +
labs(title="Distribution Comparison by Metric") +
theme_minimal() +
theme(axis.text.x=element_blank())
# 7. 热力图展示相关性
cor_heatmap <- df %>%
select(mse, cor, sil, dcor, trust, conti) %>%
cor() %>%
as.data.frame() %>%
rownames_to_column("var1") %>%
pivot_longer(cols=-var1, names_to="var2", values_to="correlation")
ggplot(cor_heatmap, aes(x=var1, y=var2, fill=correlation)) +
geom_tile() +
geom_text(aes(label=round(correlation,2)), color="white") +
scale_fill_gradient2(low="blue", mid="white", high="red") +
labs(title="Metrics Correlation Heatmap") +
theme_minimal()
View(df)
source("D:/AAA_UZH_study/Project/SNPic/snpic_evaluation_result_plot.R", echo=TRUE)
