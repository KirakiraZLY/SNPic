# 6. 箱线图比较分布
df_long <- df %>%
pivot_longer(cols=c(mse, cor, sil, dcor, trust, conti),
names_to="metric", values_to="value")
df_long$metric <- factor(df_long$metric, levels = c("mse", "cor", "sil", "dcor", "trust", "conti"))
p_box <- ggplot(df_long, aes(x=model, y=value, fill=model)) +
geom_boxplot() +
facet_wrap(~metric, scales="free_y") +
scale_fill_brewer(palette="Pastel1") +
labs(title="Distribution Comparison by Metric") +
theme_minimal() +
theme(axis.text.x=element_blank())
p_box
# 7. 热力图展示相关性
cor_heatmap <- df %>%
select(mse, cor, sil, dcor, trust, conti) %>%
cor() %>%
as.data.frame() %>%
rownames_to_column("var1") %>%
pivot_longer(cols=-var1, names_to="var2", values_to="correlation")
cor_heatmap$metric <- factor(cor_heatmap$metric, levels = c("mse", "cor", "sil", "dcor", "trust", "conti"))
View(cor_heatmap)
cor_heatmap$var1 <- factor(cor_heatmap$var1, levels = c("mse", "cor", "sil", "dcor", "trust", "conti"))
p_cor <- ggplot(cor_heatmap, aes(x=var1, y=var2, fill=correlation)) +
geom_tile() +
geom_text(aes(label=round(correlation,2)), color="white") +
scale_fill_gradient2(low="blue", mid="white", high="red") +
labs(title="Metrics Correlation Heatmap") +
theme_minimal()
